{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentReady baseline",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "generatedAt", "findings"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "prunedAt": {
      "type": "string",
      "format": "date-time"
    },
    "previousEntries": {
      "type": "integer",
      "minimum": 0
    },
    "removedEntries": {
      "type": "integer",
      "minimum": 0
    },
    "entriesPreserved": {
      "type": "integer",
      "minimum": 0
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fingerprint", "id", "severity", "title", "file", "line"],
        "properties": {
          "fingerprint": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low", "info"]
          },
          "title": {
            "type": "string"
          },
          "file": {
            "type": ["string", "null"]
          },
          "line": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "firstSeenAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastSeenAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}

